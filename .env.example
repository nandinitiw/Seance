# ── Séance environment ────────────────────────────────────────────────────────
# Copy to .env and fill in keys as your team collects them from sponsor booths.
# EVERY key is optional: with none set, the app runs in full mock mode so you can
# build the UI before any integration lands. Add keys one at a time and watch each
# hop of the pipeline switch from mock → real.

# Anthropic — the "brain": vision → persona, and the conversation replies.
# Booth: Anthropic. Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=

# Deepgram — voice in (speech-to-text) and voice out (text-to-speech).
# Booth: Deepgram. Get a key at https://console.deepgram.com
DEEPGRAM_API_KEY=
# Voice for the character. See https://developers.deepgram.com/docs/tts-models
DEEPGRAM_TTS_MODEL=aura-2-thalia-en
DEEPGRAM_STT_MODEL=nova-3

# Image generation — the character portrait. Pick ONE provider (or leave blank
# for the stylized-photo fallback, which is totally fine for the demo).
#   "mock"     → CSS-stylized version of the captured photo (default, no key)
#   "firefly"  → Adobe Firefly Services (booth: Adobe)
#   "midjourney" → via your own proxy (Midjourney has no official API)
IMAGE_PROVIDER=mock
ADOBE_FIREFLY_CLIENT_ID=
ADOBE_FIREFLY_CLIENT_SECRET=
MIDJOURNEY_PROXY_URL=
GEMINI_API_KEY=
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image

# Redis — persistent memory so the SAME object remembers you across sessions.
# Booth: Redis. Leave blank to use an in-process Map (resets on restart).
REDIS_URL=

# Server
PORT=3000
