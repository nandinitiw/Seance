# Backend URL for the Expo app.
# On-LAN (same Wi-Fi as your laptop):
#   EXPO_PUBLIC_API_URL=http://192.168.1.42:3000
# Use `ifconfig | grep "inet "` to find your laptop's LAN IP.
# Off-network (Deepgram booth etc.):
#   EXPO_PUBLIC_API_URL=https://xxxx.ngrok-free.app
EXPO_PUBLIC_API_URL=http://localhost:3000
